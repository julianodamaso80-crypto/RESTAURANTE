meta {
  name: Create Customer
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/customers/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  X-Tenant-ID: {{tenant_id}}
  X-Store-ID: {{store_id}}
}

body:json {
  {
    "name": "Maria Silva",
    "email": "maria@example.com",
    "phone": "+5585999990000"
  }
}
