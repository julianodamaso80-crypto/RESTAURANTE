meta {
  name: Create Network Template
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/enterprise/templates/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  X-Tenant-ID: {{tenant_id}}
  X-Store-ID: {{store_id}}
}

body:json {
  {
    "name": "Template Padrao Rede",
    "description": "Template com catalogo e configuracoes padrao da rede",
    "catalog_snapshot": {},
    "settings_snapshot": {}
  }
}
