# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
POSTGRES_DB=restaurante
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Environment (prod = JSON logs, dev = colored console logs)
DJANGO_ENV=dev

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# iFood Connector
IFOOD_WEBHOOK_SECRET=your-webhook-secret-here
IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_CLIENT_ID=your-ifood-client-id
IFOOD_CLIENT_SECRET=your-ifood-client-secret
IFOOD_REDIRECT_URI=http://localhost:8000/api/v1/connect/ifood/callback/
IFOOD_AUTH_BASE=https://merchant-api.ifood.com.br/authentication/v1.0

# Frontend URL (for OAuth redirects)
FRONTEND_BASE_URL=http://localhost:3000

# 99Food Connector
NINETYNINE_WEBHOOK_SECRET=your-99food-secret-here
NINETYNINE_API_BASE_URL=https://openapi.didi-food.com/v4/opendelivery
